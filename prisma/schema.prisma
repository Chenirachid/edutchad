generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Etablissement {
  id        Int      @id @default(autoincrement())
  nom       String
  code      String   @unique
  createdAt DateTime @default(now())

  utilisateurs User[]
  classes      Classe[]
  matieres     Matiere[]
  parametres   ParametrePlateforme?
  actualites   Actualite[]
  sondages     Sondage[]
}

model User {
  id                  Int       @id @default(autoincrement())
  nom                 String
  prenom              String
  email               String    @unique
  password            String
  role                Role      @default(ETUDIANT)
  numeroEtudiant      String?   @unique
  createdAt           DateTime  @default(now())
  tentativesEchouees  Int       @default(0)
  verrouJusqua        DateTime?

  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  etablissementId Int?

  classeId  Int?
  classe    Classe?  @relation("EtudiantsClasse", fields: [classeId], references: [id])

  enseignements Enseignement[] @relation("ProfesseurEnseignements")
  notes         Note[]         @relation("NotesEtudiant")
  absences      Absence[]      @relation("AbsencesEtudiant")

  enfants User[] @relation("ParentEnfant")
  parents User[] @relation("ParentEnfant")

  messagesEnvoyes Message[] @relation("MessagesEnvoyes")
  messagesRecus   Message[] @relation("MessagesRecus")

  observationsRecues   Observation[] @relation("ObservationsEtudiant")
  observationsRedigees Observation[] @relation("ObservationsAuteur")
  punitionsRecues      Punition[]    @relation("PunitionsEtudiant")
  punitionsRedigees    Punition[]    @relation("PunitionsAuteur")

  messagesGroupe MessageGroupe[]

  inscriptionsMatiere InscriptionMatiere[]
  reunionsOrganisees  Reunion[]            @relation("ReunionsOrganisees")
  invitationsReunion  InvitationReunion[]  @relation("ReunionsInvite")

  fraisScolarite FraisScolarite?

  inscriptionsAdministratives InscriptionAdministrative[]
  mentionsBulletin            MentionBulletin[]

  demandesSuppressionCible     DemandeSuppressionAdmin[] @relation("DemandeCible")
  demandesSuppressionEmises    DemandeSuppressionAdmin[] @relation("DemandeDemandeur")
  demandesSuppressionTraitees  DemandeSuppressionAdmin[] @relation("DemandeTraitant")

  creneauxRdv        CreneauRendezVous[] @relation("CreneauxRdvProf")
  reservationsRdv    ReservationRdv[]    @relation("ReservationsRdvParent")
  rendezVousEnfant   ReservationRdv[]    @relation("ReservationsRdvEtudiant")
  actualites         Actualite[]
  sondagesCrees      Sondage[]
  votesSondages      VoteSondage[]
}

enum Role {
  ETUDIANT
  PROFESSEUR
  PARENT
  ADMIN
  CHEF_PROJET
}

model Classe {
  id            Int      @id @default(autoincrement())
  nom           String
  anneeScolaire String
  createdAt     DateTime @default(now())

  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  etablissementId Int?

  etudiants     User[]         @relation("EtudiantsClasse")
  enseignements Enseignement[]
  groupe        Groupe?

  @@unique([nom, etablissementId])
}

model Matiere {
  id          Int      @id @default(autoincrement())
  nom         String
  coefficient Float    @default(1)
  createdAt   DateTime @default(now())

  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  etablissementId Int?

  enseignements Enseignement[]
  inscriptions  InscriptionMatiere[]

  @@unique([nom, etablissementId])
}

model InscriptionMatiere {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  etudiant   User    @relation(fields: [etudiantId], references: [id])
  etudiantId Int
  matiere    Matiere @relation(fields: [matiereId], references: [id])
  matiereId  Int

  @@unique([etudiantId, matiereId])
}

model Enseignement {
  id           Int     @id @default(autoincrement())
  classe       Classe  @relation(fields: [classeId], references: [id])
  classeId     Int
  matiere      Matiere @relation(fields: [matiereId], references: [id])
  matiereId    Int
  professeur   User    @relation("ProfesseurEnseignements", fields: [professeurId], references: [id])
  professeurId Int

  @@unique([classeId, matiereId])
  notes         Note[]
  absences      Absence[]
  creneaux      Creneau[]
  observations  Observation[]
  cahiersTexte  CahierTexte[]
  epreuves      Epreuve[]
}

enum TypeEvaluation {
  DEVOIR
  CONTROLE
  EXAMEN
}

model Note {
  id          Int             @id @default(autoincrement())
  valeur      Float
  coefficient Float           @default(1)
  type        TypeEvaluation  @default(CONTROLE)
  commentaire String?
  createdAt   DateTime        @default(now())

  etudiant       User         @relation("NotesEtudiant", fields: [etudiantId], references: [id])
  etudiantId     Int
  enseignement   Enseignement @relation(fields: [enseignementId], references: [id])
  enseignementId Int

  epreuve   Epreuve? @relation(fields: [epreuveId], references: [id])
  epreuveId Int?

  @@unique([etudiantId, epreuveId])
}

model Epreuve {
  id          Int            @id @default(autoincrement())
  titre       String
  type        TypeEvaluation @default(CONTROLE)
  date        DateTime
  coefficient Float          @default(1)
  createdAt   DateTime       @default(now())

  enseignement   Enseignement @relation(fields: [enseignementId], references: [id])
  enseignementId Int

  notes Note[]
}

enum TypeAbsence {
  ABSENCE
  RETARD
}

model Absence {
  id           Int          @id @default(autoincrement())
  type         TypeAbsence  @default(ABSENCE)
  date         DateTime
  justifiee    Boolean      @default(false)
  motif        String?
  dureeMinutes Int?
  createdAt    DateTime     @default(now())

  etudiant       User         @relation("AbsencesEtudiant", fields: [etudiantId], references: [id])
  etudiantId     Int
  enseignement   Enseignement @relation(fields: [enseignementId], references: [id])
  enseignementId Int
}

enum JourSemaine {
  LUNDI
  MARDI
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
}

model Creneau {
  id         Int         @id @default(autoincrement())
  jour       JourSemaine
  heureDebut String
  heureFin   String
  salle      String?
  createdAt  DateTime    @default(now())

  enseignement   Enseignement @relation(fields: [enseignementId], references: [id])
  enseignementId Int
}

model Message {
  id        Int      @id @default(autoincrement())
  contenu   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  expediteur     User @relation("MessagesEnvoyes", fields: [expediteurId], references: [id])
  expediteurId   Int
  destinataire   User @relation("MessagesRecus", fields: [destinataireId], references: [id])
  destinataireId Int
}

model ParametrePlateforme {
  id               Int      @id @default(autoincrement())
  nomEtablissement String   @default("EduCheni")
  anneeScolaire    String   @default("2025-2026")
  bareme           Int      @default(20)
  updatedAt        DateTime @updatedAt

  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  etablissementId Int?           @unique
}

enum TypeObservation {
  POSITIVE
  NEGATIVE
  NEUTRE
}

model Observation {
  id      Int             @id @default(autoincrement())
  contenu String
  type    TypeObservation @default(NEUTRE)
  date    DateTime        @default(now())

  etudiant       User          @relation("ObservationsEtudiant", fields: [etudiantId], references: [id])
  etudiantId     Int
  auteur         User          @relation("ObservationsAuteur", fields: [auteurId], references: [id])
  auteurId       Int
  enseignement   Enseignement? @relation(fields: [enseignementId], references: [id])
  enseignementId Int?
}

enum TypePunition {
  AVERTISSEMENT
  RETENUE
  EXCLUSION_TEMPORAIRE
  EXCLUSION_DEFINITIVE
}

model Punition {
  id          Int          @id @default(autoincrement())
  type        TypePunition
  motif       String
  date        DateTime     @default(now())
  dureeHeures Int?

  etudiant   User @relation("PunitionsEtudiant", fields: [etudiantId], references: [id])
  etudiantId Int
  auteur     User @relation("PunitionsAuteur", fields: [auteurId], references: [id])
  auteurId   Int
}

enum TypeGroupe {
  CLASSE
  PROFS
  ADMIN
}

model Groupe {
  id        Int        @id @default(autoincrement())
  nom       String
  type      TypeGroupe
  createdAt DateTime   @default(now())

  classe   Classe? @relation(fields: [classeId], references: [id])
  classeId Int?    @unique

  messages MessageGroupe[]
}

model MessageGroupe {
  id        Int      @id @default(autoincrement())
  contenu   String
  createdAt DateTime @default(now())

  groupe   Groupe @relation(fields: [groupeId], references: [id])
  groupeId Int
  auteur   User   @relation(fields: [auteurId], references: [id])
  auteurId Int
}

enum StatutInvitation {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

model Reunion {
  id        Int      @id @default(autoincrement())
  sujet     String
  lieu      String?
  date      DateTime
  createdAt DateTime @default(now())

  organisateur   User @relation("ReunionsOrganisees", fields: [organisateurId], references: [id])
  organisateurId Int

  invitations InvitationReunion[]
}

model InvitationReunion {
  id        Int              @id @default(autoincrement())
  reponse   StatutInvitation @default(EN_ATTENTE)
  createdAt DateTime         @default(now())

  reunion   Reunion @relation(fields: [reunionId], references: [id])
  reunionId Int
  invite    User    @relation("ReunionsInvite", fields: [inviteId], references: [id])
  inviteId  Int

  @@unique([reunionId, inviteId])
}

model CahierTexte {
  id        Int      @id @default(autoincrement())
  date      DateTime
  contenu   String
  devoirs   String?
  createdAt DateTime @default(now())

  pieceJointeNom  String?
  pieceJointeType String?
  pieceJointeData String? @db.Text

  enseignement   Enseignement @relation(fields: [enseignementId], references: [id])
  enseignementId Int
}

model FraisScolarite {
  id            Int      @id @default(autoincrement())
  montantTotal  Float
  anneeScolaire String
  createdAt     DateTime @default(now())

  etudiant   User @relation(fields: [etudiantId], references: [id])
  etudiantId Int  @unique

  versements Versement[]
}

model Versement {
  id        Int      @id @default(autoincrement())
  montant   Float
  moyen     String?
  date      DateTime @default(now())

  frais   FraisScolarite @relation(fields: [fraisId], references: [id])
  fraisId Int
}

enum StatutInscriptionAdmin {
  EN_ATTENTE
  VALIDEE
  REFUSEE
}

model InscriptionAdministrative {
  id             Int                    @id @default(autoincrement())
  anneeScolaire  String
  statut         StatutInscriptionAdmin @default(EN_ATTENTE)
  dateValidation DateTime?
  createdAt      DateTime               @default(now())

  etudiant   User @relation(fields: [etudiantId], references: [id])
  etudiantId Int

  @@unique([etudiantId, anneeScolaire])
}

enum Mention {
  EN_ATTENTE
  ADMIS
  AJOURNE
}

model MentionBulletin {
  id            Int      @id @default(autoincrement())
  anneeScolaire String
  mention       Mention  @default(EN_ATTENTE)
  appreciation  String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  etudiant   User @relation(fields: [etudiantId], references: [id])
  etudiantId Int

  @@unique([etudiantId, anneeScolaire])
}

enum StatutDemande {
  EN_ATTENTE
  APPROUVEE
  REJETEE
}

model DemandeSuppressionAdmin {
  id        Int           @id @default(autoincrement())
  statut    StatutDemande @default(EN_ATTENTE)
  createdAt DateTime      @default(now())
  traiteLe  DateTime?

  cible       User  @relation("DemandeCible", fields: [cibleId], references: [id])
  cibleId     Int
  demandeur   User  @relation("DemandeDemandeur", fields: [demandeurId], references: [id])
  demandeurId Int
  traitePar   User? @relation("DemandeTraitant", fields: [traiteParId], references: [id])
  traiteParId Int?
}

model CreneauRendezVous {
  id           Int      @id @default(autoincrement())
  date         DateTime
  dureeMinutes Int      @default(15)
  createdAt    DateTime @default(now())

  professeur   User @relation("CreneauxRdvProf", fields: [professeurId], references: [id])
  professeurId Int

  reservation ReservationRdv?
}

model ReservationRdv {
  id        Int      @id @default(autoincrement())
  motif     String?
  createdAt DateTime @default(now())

  creneau   CreneauRendezVous @relation(fields: [creneauId], references: [id])
  creneauId Int               @unique
  parent    User @relation("ReservationsRdvParent", fields: [parentId], references: [id])
  parentId  Int
  etudiant  User @relation("ReservationsRdvEtudiant", fields: [etudiantId], references: [id])
  etudiantId Int
}

model Actualite {
  id        Int      @id @default(autoincrement())
  titre     String
  contenu   String
  createdAt DateTime @default(now())

  auteur          User           @relation(fields: [auteurId], references: [id])
  auteurId        Int
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  etablissementId Int?
}

model Sondage {
  id        Int      @id @default(autoincrement())
  question  String
  cloture   Boolean  @default(false)
  createdAt DateTime @default(now())

  auteur          User           @relation(fields: [auteurId], references: [id])
  auteurId        Int
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])
  etablissementId Int?

  options OptionSondage[]
  votes   VoteSondage[]
}

model OptionSondage {
  id        Int    @id @default(autoincrement())
  texte     String

  sondage   Sondage @relation(fields: [sondageId], references: [id])
  sondageId Int

  votes VoteSondage[]
}

model VoteSondage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  option    OptionSondage @relation(fields: [optionId], references: [id])
  optionId  Int
  sondage   Sondage       @relation(fields: [sondageId], references: [id])
  sondageId Int
  votant    User          @relation(fields: [votantId], references: [id])
  votantId  Int

  @@unique([sondageId, votantId])
}